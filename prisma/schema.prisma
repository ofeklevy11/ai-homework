generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id        String   @id @default(cuid())
  name      String   @unique // "mika" or "rom"
  createdAt DateTime @default(now())

  quizSubmissions QuizSubmission[]
}

model QuizSubmission {
  id          String   @id @default(cuid())
  studentId   String
  quizId      String   // e.g. "lesson1"
  score       Int
  totalQuestions Int
  percentage  Int
  answers     QuizAnswer[]
  submittedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([quizId])
}

model QuizAnswer {
  id              String   @id @default(cuid())
  submissionId    String
  questionIndex   Int
  selectedAnswer  Int
  correctAnswer   Int
  isCorrect       Boolean

  submission QuizSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}
